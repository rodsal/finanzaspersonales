# Flask Configuration
SECRET_KEY=dev-secret-key-change-in-production-12345
DEBUG=True
FLASK_ENV=development

# Database Configuration
# Usa postgresql+psycopg:// para psycopg3 o postgresql:// para psycopg2
# PostgreSQL 18 en puerto 5437
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5437/finanzas_personales

# CORS Configuration
CORS_ORIGINS=*

# API Configuration
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=100

# Timezone
TIMEZONE=America/Costa_Rica
